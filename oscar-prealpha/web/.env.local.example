# Hash SHA-256 du mot de passe partagé. Générer :
#   printf 'TON_MOT_DE_PASSE' | shasum -a 256 | cut -d' ' -f1
OSCAR_PASSWORD_SHA256=
# Secret de signature du cookie (≥32 caractères aléatoires). Générer :
#   openssl rand -hex 32
OSCAR_SESSION_SECRET=

# --- Édition du tableau des correspondances (Paramètres › Équivalences) --------
# Magasin KV REST (Upstash / Vercel KV) pour persister les modifications de
# correspondances catégorie→secteur. Sans ces variables, l'édition marche en
# LOCAL (fichier server/data/mapping_overrides.json) mais reste en lecture seule
# en production (FS Vercel non inscriptible).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Assistant OSCAR AI (LLM) --------------------------------------------------
# Clé API Albert (Etalab) ou tout endpoint OpenAI-compatible. Sans clé,
# l'assistant bascule sur le moteur déterministe local (réponses simples).
ALBERT_API_KEY=
# Optionnels (valeurs par défaut) :
# ALBERT_BASE_URL=https://albert.api.etalab.gouv.fr/v1
# ALBERT_MODEL=albert-large
